# ============================================================
# 远程数据库连接串 (支持 PostgreSQL / MySQL / 等)
# 复制此文件为 .env.local 并填入真实值
# .env.local 已被 .gitignore 忽略，不会提交到 git
# ============================================================
REMOTE_DB_URL=postgresql://user:password@host/database?sslmode=require
